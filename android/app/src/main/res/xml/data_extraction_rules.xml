<?xml version="1.0" encoding="utf-8"?>
<!-- Ride history is device-only: never copied to cloud backup or device transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="secure_store.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secure_store.xml" />
    </device-transfer>
</data-extraction-rules>
