<?xml version="1.0" encoding="utf-8"?>
<!-- Auth token and driver data are device-only: no cloud backup or transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="secure_store.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secure_store.xml" />
    </device-transfer>
</data-extraction-rules>
