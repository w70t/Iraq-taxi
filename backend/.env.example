# انسخ هذا الملف إلى .env وعدّل القيم. لا ترفع .env إلى Git أبداً.

# مفتاح التوقيع — ولّد واحداً بـ: python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=

# رمز لوحة التحكم /admin (العمولة والتسعير) — ولّده بـ:
# python -c "import secrets;print(secrets.token_urlsafe(24))"
# اتركه فارغاً لتعطيل لوحة التحكم كلياً.
ADMIN_TOKEN=

# قاعدة البيانات: SQLite افتراضياً للتطوير المحلي.
# في الإنتاج (docker-compose.prod.yml) تُضبط تلقائياً على PostgreSQL — لا تغيّرها هنا.
DATABASE_URL=sqlite:///./taxi.db

# Redis لتوزيع تحديثات WebSocket على عدة عمال — يُضبط تلقائياً في الإنتاج.
# اتركه فارغاً للتطوير المحلي (وضع العملية الواحدة).
REDIS_URL=

# ===== الإنتاج (docker-compose.prod.yml) =====
# كلمة سر PostgreSQL — ولّدها بـ: python -c "import secrets;print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=
# النطاق الذي يشير إلى خادمك — Caddy يصدر شهادة HTTPS له تلقائياً
DOMAIN=taxi.example.com
# عدد عمال uvicorn (2 مناسب لـ Raspberry Pi 5)
API_WORKERS=2

# للتطوير فقط: يعيد رمز OTP في الاستجابة بدل SMS — عطّله في الإنتاج!
OTP_ECHO=true

# في الإنتاج: false ثم اعتماد السائقين يدوياً بعد فحص المستمسكات
DRIVER_AUTO_APPROVE=true

# ===== زين كاش (من عقد التاجر مع زين العراق) =====
# للتجربة: https://test.zaincash.iq — للإنتاج: https://api.zaincash.iq
ZAINCASH_BASE_URL=https://test.zaincash.iq
ZAINCASH_MSISDN=
ZAINCASH_MERCHANT_ID=
ZAINCASH_SECRET=
ZAINCASH_REDIRECT_URL=https://YOUR_DOMAIN/payments/zaincash/callback

# ===== FIB المصرف العراقي الأول (من بوابة تجار FIB) =====
# للتجربة: https://fib.stage.fib.iq
FIB_BASE_URL=https://fib.stage.fib.iq
FIB_CLIENT_ID=
FIB_CLIENT_SECRET=
